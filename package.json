{
  "name": "mstc-dashboard",
  "version": "1.3.1",
  "description": "Electron race-engineering dashboard for live timing, pace analysis and pit strategy.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "node tests/run-all.js",
    "test:coverage": "node --test --experimental-test-coverage tests/*.test.js",
    "dist": "electron-builder --publish never",
    "dist:win": "electron-builder --win nsis --publish never",
    "dist:mac": "electron-builder --mac dmg zip --publish never"
  },
  "keywords": [
    "livetiming",
    "motorsport",
    "electron",
    "zolder"
  ],
  "author": "Jeff Mathieu",
  "license": "MIT",
  "engines": {
    "node": ">=20.19.0"
  },
  "devDependencies": {
    "electron": "^41.7.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.jeffmathieu.mstcraceengineerdashboard",
    "productName": "MSTC Dashboard",
    "asar": true,
    "asarUnpack": [
      "src/main/reports/*.py"
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "directories": {
      "output": "dist",
      "buildResources": "docs/mstc_app_icons/electron-builder/build"
    },
    "files": [
      "src/**/*",
      "!**/__pycache__/**",
      "!**/*.pyc",
      "package.json"
    ],
    "publish": {
      "provider": "github",
      "owner": "jeffmathieu",
      "repo": "MSTC-Internship",
      "releaseType": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "docs/mstc_app_icons/electron-builder/build/icon.ico",
      "artifactName": "MSTC-Dashboard-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "docs/mstc_app_icons/electron-builder/build/icon.ico",
      "uninstallerIcon": "docs/mstc_app_icons/electron-builder/build/icon.ico"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "docs/mstc_app_icons/electron-builder/build/icon.icns",
      "category": "public.app-category.sports",
      "artifactName": "MSTC-Dashboard-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
